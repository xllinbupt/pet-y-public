  "behavior": {
    "home_states": [
      "idle",
      "sit",
      "sleep"
    ],
    "away_states": [
      "departing",
      "visiting",
      "returning"
    ],
    "state_transitions": [
      {
        "from": "idle",
        "to": "run",
        "trigger": "move_to_target"
      },
      {
        "from": "idle",
        "to": "sit",
        "trigger": "user_nearby"
      },
      {
        "from": "idle",
        "to": "sleep",
        "trigger": "inactive_for_10_minutes"
      },
      {
        "from": "visit_returned",
        "to": "carry_ball",
        "trigger": "returned_with_gift:ball"
      }
    ],
    "interactions": {
      "click": {
        "reaction": "bubble",
        "memory_weight": "low"
      },
      "drag": {
        "reaction": "bubble",
        "memory_weight": "medium"
      },
      "feed": {
        "reaction": "bubble",
        "memory_weight": "high"
      },
      "fetch_ball": {
        "trigger": "interaction_menu:throw_ball",
        "sequence": [
          "throw_ball_far",
          "run_to_ball_scale_down",
          "pick_up_ball",
          "carry_ball_back_scale_up",
          "sit"
        ],
        "reaction": "movement_animation",
        "memory_weight": "high"
      },
      "pet": {
        "trigger": "interaction_menu:pet",
        "sequence": [
          "sit",
          "bubble_response"
        ],
        "reaction": "affection_animation",
        "memory_weight": "medium"
      },
      "sleep_now": {
        "trigger": "interaction_menu:sleep",
        "sequence": [
          "sleep"
        ],
        "reaction": "state_change",
        "memory_weight": "low"
      }
    }
