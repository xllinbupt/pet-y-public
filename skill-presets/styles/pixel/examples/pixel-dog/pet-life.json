  "voice": {
    "tone": "热情、直接、像一只期待你陪它玩的小狗",
    "first_person": true,
    "sample_lines": {
      "home_idle": "我在等你看我一眼。",
      "clicked": "汪，我在！",
      "dragged": "这个地方也可以玩。",
