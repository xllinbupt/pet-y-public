  "asset_prompts": {
    "style_prompt": "像素风小狗桌面宠物，64x64 单帧规格，透明背景，暖黄色身体，深色耳朵，清晰轮廓，有限色板。",
    "state_prompts": {
      "idle": "同一只像素风小狗的 4 帧横向 sprite sheet，站着摇尾巴，偶尔眨眼，透明背景。",
      "run": "同一只像素风小狗的 6 帧横向 sprite sheet，小跑动作，耳朵和尾巴上下动，透明背景。",
      "sit": "同一只像素风小狗的 3 帧横向 sprite sheet，坐着看向用户，尾巴轻轻动，透明背景。",
      "sleep": "同一只像素风小狗的 3 帧横向 sprite sheet，趴着睡觉，身体有呼吸起伏，透明背景。",
      "carry_ball": "同一只像素风小狗的 6 帧横向 sprite sheet，叼着红色皮球小跑过来，透明背景。"
    }
  },
  "behavior": {
    "home_states": [
      "idle",
      "sit",
      "sleep"
    ],
    "away_states": [
      "departing",
      "visiting",
      "returning"
    ],
    "state_transitions": [
      {
        "from": "idle",
        "to": "run",
        "trigger": "move_to_target"
      },
      {
        "from": "idle",
        "to": "sit",
        "trigger": "user_nearby"
      },
      {
        "from": "idle",
        "to": "sleep",
        "trigger": "inactive_for_10_minutes"
      },
      {
        "from": "visit_returned",
        "to": "carry_ball",
        "trigger": "returned_with_gift:ball"
      }
    ],
    "interactions": {
      "click": {
        "reaction": "bubble",
        "memory_weight": "low"
      },
      "drag": {
        "reaction": "bubble",
        "memory_weight": "medium"
      },
      "feed": {
        "reaction": "bubble",
        "memory_weight": "high"
      },
      "fetch_ball": {
        "trigger": "interaction_menu:throw_ball",
        "sequence": [
          "throw_ball_far",
          "run_to_ball_scale_down",
          "pick_up_ball",
          "carry_ball_back_scale_up",
          "sit"
        ],
        "reaction": "movement_animation",
        "memory_weight": "high"
      },
      "pet": {
        "trigger": "interaction_menu:pet",
        "sequence": [
          "sit",
          "bubble_response"
        ],
        "reaction": "affection_animation",
        "memory_weight": "medium"
      },
      "sleep_now": {
        "trigger": "interaction_menu:sleep",
        "sequence": [
          "sleep"
        ],
        "reaction": "state_change",
        "memory_weight": "low"
      }
    }
  },
  "memory_rules": {
    "summary_style": "像小狗一样直接、开心地讲述经历。",
    "remember_events": [
      "dragged",
      "fed",
      "host_runtime_offline",
      "host_requested_return"
    ]
  },
  "visit_preferences": {
    "likes_visiting": true,
    "default_intent": "play",
    "default_mood": "excited",
    "carried_items": [
      "ball"
    ]
  }
